<!--
  Add this element inside the <devices> section of the HAOS VM.
  Run: virsh edit haos

  This creates:
    Host:  /run/bt-hci-proxy.sock  (UNIX socket)
    VM:    /dev/ttyAMA1  (second serial port)

  Note: Uses a serial port (not virtio-serial) because btattach
  requires a tty device that supports termios ioctls.
  tianq: arm soc doesn't has a ISA bus, try pl011
  you may see logs like below, that's completely normal
  hci-proxy: Connected to virtio-serial at /run/bt-hci-proxy.sock
-->

<serial type='unix'>
  <source mode='bind' path='/run/bt-hci-proxy.sock'/>
  <target type='system-serial' port='1'>
    <model name='pl011'/>
  </target>
</serial>